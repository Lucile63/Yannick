  function renderAlerts(active, ratio){
    const alerts = [];
    const a = getWeekActuals(active);
    if ((active.type === "récupération" || active.objectif.toLowerCase().includes("assimilation")) && a.km > active.kmMax * 1.1) alerts.push(["red","Semaine récupération au-dessus de 110 % du kmMax. Dérive détectée. Réduis avant de subir."]);
    if ((active.type === "récupération" || active.objectif.toLowerCase().includes("assimilation")) && active.dpMax > 0 && a.dp > active.dpMax * 1.1) alerts.push(["red","Semaine récupération au-dessus de 110 % du D+ max. Risque inutile."]);
    const last = latestEntryDate();
    if (!last || (today() - last) / 86400000 > 14) alerts.push(["orange","Saisie en retard. Sans données, le pilotage est aveugle."]);
    if (a.freshness && a.freshness <= 3) alerts.push(["red","Fraîcheur basse. Supprimer l’intensité, garder le facile."]);
    const noteText = `${a.notes} ${a.achilles}`.toLowerCase();
    if (noteText.includes("achille") || noteText.includes("mollet") || a.achilles === "oui") alerts.push(["red","Alerte mollet/Achille. Intensité interdite 3 à 5 jours."]);
    if (active.id === 16 && (a.km > 92 || a.dp > 3600)) alerts.push(["red","Semaine pic au-dessus du plan. Risque inutile."]);
    if (ratio != null && (ratio > 1.5 || ratio < .5)) alerts.push(["red","ATL/CTL hors zone rouge. Surcharge ou désentraînement détecté."]);
    else if (ratio != null && !(ratio >= .8 && ratio <= 1.3)) alerts.push(["orange","ATL/CTL hors zone verte. Ajustement nécessaire."]);
    if (!alerts.length) alerts.push(["green","Charge cohérente. Continue. Le D+ compte plus que le volume plat pour cette course."]);
    $("#alertsBox").innerHTML = alerts.map(a => `<div class="card alert-${a[0]}"><strong>${a[1]}</strong></div>`).join("");
  }

