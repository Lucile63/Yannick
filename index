<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TransLantau 104 — Préparation Yannick</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js" integrity="sha512-D/fkxORGQ+OSpEVR3VILlBiYItrh2B080KSDNF9nQFWHyksLlyPuU7mCV5Lu8u0Md9gE5wErNV0h7LNIWMW6fA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <style>
    :root{
      --bg:#0A0C0F;
      --panel:#10141A;
      --panel2:#151A21;
      --line:#242B35;
      --text:#F5F7FA;
      --muted:#8A8F9A;
      --orange:#E8622A;
      --orange2:#FF742E;
      --green:#1DB37A;
      --blue:#2E8FE0;
      --red:#E83A2A;
      --light:#D6DAE2;
      --radius:4px;
      --shadow:0 0 0 1px rgba(232,98,42,.18),0 18px 42px rgba(0,0,0,.36);
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{margin:0;background:radial-gradient(circle at 70% 0%,rgba(232,98,42,.12),transparent 30%),linear-gradient(180deg,#0A0C0F 0%,#07090B 100%);color:var(--text);font-family:Inter,system-ui,-apple-system,Segoe UI,sans-serif;line-height:1.4;min-height:100vh}
    button,input,select,textarea{font:inherit}
    button{cursor:pointer}
    a{color:inherit}
    .progress-rail{position:fixed;left:0;top:0;width:7px;height:100vh;background:#15191F;z-index:20;overflow:hidden}
    .progress-fill{position:absolute;left:0;bottom:0;width:100%;height:0;background:linear-gradient(180deg,var(--orange2),var(--orange),var(--green));box-shadow:0 0 20px rgba(232,98,42,.8);transition:height .9s ease}
    .site{width:min(1500px,calc(100% - 34px));margin:0 auto;padding:24px 0 48px}
    .hero{position:relative;display:grid;grid-template-columns:1.2fr .8fr;gap:18px;min-height:420px;padding:26px;border:1px solid var(--line);border-radius:var(--radius);background:linear-gradient(135deg,rgba(17,22,29,.92),rgba(10,12,15,.94)),radial-gradient(circle at 15% 20%,rgba(232,98,42,.18),transparent 28%);overflow:hidden;box-shadow:var(--shadow)}
    .hero:after{content:"";position:absolute;inset:auto -10% -40% 25%;height:260px;background:linear-gradient(90deg,transparent,rgba(232,98,42,.13),transparent);transform:rotate(-8deg);pointer-events:none}
    h1,h2,h3,.display{font-family:"Bebas Neue",Inter,sans-serif;letter-spacing:.03em;font-weight:400;text-transform:uppercase;margin:0}
    h1{font-size:clamp(54px,9vw,132px);line-height:.82;max-width:900px}
    h2{font-size:clamp(32px,5vw,58px);line-height:.95;margin-bottom:12px}
    h3{font-size:28px;line-height:1}
    .subtitle{font-size:18px;color:var(--muted);font-weight:700;margin:14px 0 26px;text-transform:uppercase;letter-spacing:.08em}
    .mantra-hero{min-height:44px;font-family:"Bebas Neue";font-size:clamp(28px,4vw,52px);color:var(--orange);letter-spacing:.035em;transition:opacity .45s ease;max-width:900px}
    .rule-key{margin-top:20px;border-left:4px solid var(--orange);padding:12px 14px;background:rgba(232,98,42,.08);font-weight:800;text-transform:uppercase;max-width:640px}
    .count-box{align-self:stretch;display:flex;flex-direction:column;gap:14px;justify-content:space-between;z-index:1}
    .count-main{background:rgba(0,0,0,.28);border:1px solid var(--line);border-radius:var(--radius);padding:18px}
    .count-label{color:var(--muted);font-size:12px;text-transform:uppercase;letter-spacing:.12em;font-weight:800;margin-bottom:8px}
    .count-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
    .count-unit{border:1px solid #2a313b;background:#0D1117;padding:10px;border-radius:var(--radius);text-align:center;animation:countPulse 2.2s infinite alternate ease-in-out}
    .count-value{font-family:"Bebas Neue";font-size:clamp(34px,5vw,64px);line-height:1;color:#fff}
    .count-name{font-size:11px;color:var(--muted);text-transform:uppercase;font-weight:700}
    .subcounts{display:grid;gap:8px}
    .subcount{display:flex;justify-content:space-between;gap:12px;align-items:center;background:#0D1117;border:1px solid var(--line);border-radius:var(--radius);padding:10px 12px}
    .subcount strong{font-size:13px;text-transform:uppercase}.subcount span{font-weight:800;color:var(--orange)}
    @keyframes countPulse{from{box-shadow:0 0 0 rgba(232,98,42,0)}to{box-shadow:0 0 18px rgba(232,98,42,.16)}}
    .topnav{display:flex;flex-wrap:wrap;gap:8px;margin:18px 0 20px;position:sticky;top:0;z-index:15;padding:10px 0;background:rgba(10,12,15,.84);backdrop-filter:blur(10px)}
    .topnav a,.btn{border:1px solid var(--line);background:#10141A;color:var(--text);border-radius:var(--radius);padding:10px 12px;font-size:12px;text-transform:uppercase;letter-spacing:.07em;font-weight:800;text-decoration:none;transition:.18s ease}
    .topnav a:hover,.btn:hover{border-color:var(--orange);color:#fff;background:#151A21}.btn.orange{background:var(--orange);border-color:var(--orange);color:#050505}.btn.danger{border-color:rgba(232,58,42,.5);color:#ffb2aa}.btn.ghost{background:transparent}
    section{margin-top:22px;padding:20px;border:1px solid var(--line);background:rgba(16,20,26,.88);border-radius:var(--radius);box-shadow:0 18px 38px rgba(0,0,0,.18)}
    .section-head{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:16px}.section-head p{margin:0;color:var(--muted);font-size:13px;max-width:760px}.section-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap}.toggle-row{display:flex;align-items:center;gap:8px;color:var(--muted);font-size:12px;text-transform:uppercase;font-weight:800}
    .grid{display:grid;gap:12px}.kpi-grid{grid-template-columns:repeat(6,minmax(0,1fr))}.two{grid-template-columns:repeat(2,minmax(0,1fr))}.three{grid-template-columns:repeat(3,minmax(0,1fr))}.four{grid-template-columns:repeat(4,minmax(0,1fr))}
    .card{border:1px solid var(--line);background:linear-gradient(180deg,#121720,#0D1117);border-radius:var(--radius);padding:14px;min-width:0;transition:.18s ease}.card:hover{border-color:#343d49}.card.alert-red{border-color:rgba(232,58,42,.65);background:linear-gradient(180deg,rgba(232,58,42,.12),#0D1117)}.card.alert-orange{border-color:rgba(232,98,42,.65)}.card.alert-green{border-color:rgba(29,179,122,.45)}
    .kpi-title{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.09em;font-weight:800}.kpi-value{font-family:"Bebas Neue";font-size:clamp(30px,3.5vw,50px);line-height:1;color:#fff;margin-top:6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.kpi-sub{font-size:12px;color:var(--muted);margin-top:6px}.small-value{font-size:28px}.badge{display:inline-flex;align-items:center;gap:6px;padding:5px 8px;border:1px solid var(--line);border-radius:var(--radius);font-size:11px;letter-spacing:.07em;text-transform:uppercase;font-weight:900;background:#0D1117;color:#fff}.badge.charge{border-color:rgba(232,98,42,.45);color:#ffa06e}.badge.spécifique,.badge.specifique{border-color:rgba(232,98,42,.7);color:#ff742e}.badge.récupération,.badge.recuperation{border-color:rgba(29,179,122,.55);color:#59e4ad}.badge.pic{border-color:rgba(46,143,224,.6);color:#8bc6ff}.badge.course-préparatoire,.badge.course-preparatoire{border-color:rgba(255,116,46,.9);color:#ff7b39}.badge.affûtage,.badge.affutage{border-color:rgba(214,218,226,.55);color:#e2e6ed}.badge.race{border-color:rgba(255,116,46,1);color:#fff;background:rgba(232,98,42,.18);animation:racePulse 1.8s infinite ease-in-out}
    @keyframes racePulse{0%,100%{box-shadow:0 0 0 rgba(232,98,42,0)}50%{box-shadow:0 0 24px rgba(232,98,42,.45)}}
    .bar{height:9px;background:#252C35;border-radius:var(--radius);overflow:hidden;margin-top:10px}.bar>span{display:block;height:100%;width:0;background:var(--orange);transition:width .8s ease}.bar.green>span{background:var(--green)}.bar.blue>span{background:var(--blue)}.bar.red>span{background:var(--red)}.bar.gray>span{background:var(--light)}
    .split-panel{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(320px,.8fr);gap:12px}.chart-wrap{position:relative;min-height:360px}.chart-wrap.small{min-height:300px}canvas{width:100%!important;max-height:430px}.chart-form{display:none;border:1px solid rgba(232,98,42,.35);background:#0D1117;padding:12px;border-radius:var(--radius);margin-top:12px}.chart-form.active{display:block}
    .timeline{display:flex;gap:12px;overflow-x:auto;padding:6px 2px 12px;scroll-snap-type:x proximity}.week-card{min-width:260px;scroll-snap-align:start;border:1px solid var(--line);background:#0D1117;border-radius:var(--radius);padding:14px;text-align:left;color:var(--text);transition:.18s ease}.week-card:hover,.week-card:focus{border-color:var(--orange);outline:none;transform:translateY(-2px)}.week-card.active{border:2px solid var(--orange);transform:scale(1.02);box-shadow:0 0 26px rgba(232,98,42,.22)}.week-card.race{animation:racePulse 1.8s infinite ease-in-out}.week-top{display:flex;align-items:start;justify-content:space-between;gap:8px}.week-id{font-family:"Bebas Neue";font-size:42px;color:#fff}.week-date{font-size:12px;color:var(--muted);font-weight:800;text-transform:uppercase}.week-objectif{font-weight:800;margin:12px 0 8px}.week-meta{font-size:12px;color:var(--muted);display:grid;gap:5px}.status{margin-top:10px;font-weight:900;font-size:12px;text-transform:uppercase;color:var(--muted)}
    .drawer{position:fixed;right:0;top:0;height:100vh;width:min(560px,100%);background:#0D1117;border-left:1px solid var(--line);box-shadow:-18px 0 48px rgba(0,0,0,.55);z-index:40;padding:20px;overflow:auto;transform:translateX(105%);transition:transform .24s ease}.drawer.open{transform:translateX(0)}.drawer-head{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:14px}.close{background:#151A21;border:1px solid var(--line);color:#fff;border-radius:var(--radius);padding:9px 11px}
    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}.field{display:grid;gap:6px}.field.full{grid-column:1/-1}.field label{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-weight:900}.field input,.field select,.field textarea{width:100%;background:#090C10;border:1px solid #27303B;color:#fff;border-radius:var(--radius);padding:10px;min-height:41px}.field textarea{min-height:96px;resize:vertical}.field input:focus,.field select:focus,.field textarea:focus{outline:2px solid rgba(232,98,42,.5);border-color:var(--orange)}.range-line{display:flex;align-items:center;gap:10px}.range-line input{flex:1}.range-line span{font-weight:900;color:var(--orange);min-width:28px}.seance-list{margin:12px 0 0;padding-left:18px;color:#DDE2EA}.seance-list li{margin:7px 0}.coach-note{border-left:4px solid var(--orange);padding:10px 12px;background:rgba(232,98,42,.08);font-weight:800;color:#fff;margin:12px 0}.session-cards{display:grid;gap:10px;margin-top:12px}.session-card{border:1px solid var(--line);background:#0A0E13;border-radius:var(--radius);padding:12px}.session-head{display:flex;justify-content:space-between;gap:10px;align-items:flex-start;margin-bottom:8px}.session-code{font-family:"Bebas Neue";font-size:26px;color:var(--orange);line-height:1}.session-type{font-weight:900;color:#fff}.session-meta{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:6px;margin:8px 0}.session-meta span{border:1px solid #26303B;background:#090C10;padding:6px 8px;border-radius:var(--radius);font-size:12px;color:#DDE2EA}.session-content{font-weight:800;margin:8px 0}.session-consigne{color:#C8CDD5;border-left:3px solid var(--blue);padding-left:9px;margin-top:8px}.source-notes{margin-top:12px;display:grid;gap:8px}
    .phase-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.phase-title{font-family:"Bebas Neue";font-size:31px}.phase-weeks{color:var(--muted);font-size:12px;text-transform:uppercase;font-weight:800}.metric-line{display:flex;justify-content:space-between;gap:10px;margin:8px 0;color:#DDE2EA;font-size:13px}.metric-line strong{color:#fff}.radar-layout{display:grid;grid-template-columns:minmax(0,1fr) minmax(280px,420px);gap:16px;align-items:start}.slider-list{display:grid;gap:12px}.slider-row{display:grid;gap:6px}.slider-row label{display:flex;justify-content:space-between;font-size:12px;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);font-weight:900}.slider-row input{width:100%;accent-color:var(--orange)}
    .journal-layout{display:grid;grid-template-columns:minmax(280px,420px) minmax(0,1fr);gap:14px}.journal-list{display:grid;gap:10px;max-height:560px;overflow:auto;padding-right:4px}.journal-item{border:1px solid var(--line);background:#0D1117;padding:12px;border-radius:var(--radius)}.journal-head{display:flex;justify-content:space-between;gap:10px}.journal-head strong{font-family:"Bebas Neue";font-size:26px}.journal-meta{color:var(--muted);font-size:12px}.journal-note{margin-top:8px;color:#DCE1EA}.filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}.filters input,.filters select{background:#090C10;border:1px solid #27303B;color:#fff;border-radius:var(--radius);padding:9px}.month-summary{margin-top:12px;color:#DCE1EA;font-size:13px;display:grid;gap:6px}
    details{border:1px solid var(--line);background:#0D1117;border-radius:var(--radius);padding:12px}summary{font-weight:900;text-transform:uppercase;letter-spacing:.06em;cursor:pointer}.rules-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:12px}.rules-grid ol,.rules-grid ul{margin:10px 0 0;padding-left:20px}.rules-grid li{margin:7px 0}.adjust-table{width:100%;border-collapse:collapse;margin-top:12px;font-size:13px}.adjust-table th,.adjust-table td{border:1px solid var(--line);padding:9px;text-align:left}.adjust-table th{color:#fff;background:#121820;text-transform:uppercase;font-size:11px;letter-spacing:.08em}.adjust-table td:first-child{font-weight:800;color:#fff}
    .quote-carousel{position:relative;overflow:hidden;border:1px solid var(--line);background:#0D1117;border-radius:var(--radius);min-height:170px}.quote-track{display:flex;transition:transform .45s ease}.quote-slide{min-width:100%;padding:28px}.quote-slide div{font-family:"Bebas Neue";font-size:clamp(38px,7vw,94px);line-height:.9;color:#fff}.quote-nav{display:flex;gap:8px;margin-top:10px}.footer{margin-top:24px;border-top:1px solid var(--line);padding:22px 0 8px;color:var(--muted)}.footer-title{font-family:"Bebas Neue";font-size:56px;color:#fff}.profile-svg{width:100%;height:120px;margin:8px 0 12px;border:1px solid var(--line);background:#0D1117;border-radius:var(--radius)}.profile-path{fill:none;stroke:var(--orange);stroke-width:4;stroke-linecap:round;stroke-linejoin:round;stroke-dasharray:700;stroke-dashoffset:700;animation:drawProfile 4s ease forwards infinite alternate}.profile-fill{fill:rgba(232,98,42,.10)}@keyframes drawProfile{to{stroke-dashoffset:0}}
    .note{font-size:12px;color:var(--muted)}.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}.hide{display:none!important}.color-green{color:var(--green)}.color-orange{color:var(--orange)}.color-red{color:var(--red)}.color-blue{color:var(--blue)}
    @media (max-width:1100px){.hero,.split-panel,.radar-layout,.journal-layout{grid-template-columns:1fr}.kpi-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.phase-grid,.rules-grid{grid-template-columns:1fr 1fr}.count-box{align-self:auto}}
    @media (max-width:720px){.site{width:min(100% - 20px,1500px);padding-top:12px}.hero{padding:16px}.count-grid{grid-template-columns:repeat(2,1fr)}.kpi-grid,.two,.three,.four,.phase-grid,.rules-grid{grid-template-columns:1fr}.section-head{display:block}.section-actions{margin-top:10px}.form-grid{grid-template-columns:1fr}.drawer{padding:14px}.topnav{position:static}.week-card{min-width:230px}.footer-title{font-size:40px}}
  </style>
</head>
<body>
  <div class="progress-rail" aria-hidden="true"><div class="progress-fill" id="verticalProgress"></div></div>
  <main class="site">
    <header class="hero" id="top">
      <div>
        <div class="badge race">Race target · 13.11.2026</div>
        <h1>TransLantau 104 — Préparation Yannick</h1>
        <p class="subtitle">104 km · 4500 D+ · Hong Kong · 13.11.2026</p>
        <p class="note">Source unique : plan_source_verite_V6.md · séances détaillées vérifiées.</p>
        <div class="mantra-hero" id="heroMantra" aria-live="polite">RPE → terrain → durée → D+ → FC en garde-fou.</div>
        <div class="rule-key">Priorité source V6 : temps + D+ + RPE. Si distance et terrain contredisent, le temps et le D+ font foi.</div>
      </div>
      <aside class="count-box" aria-label="Compte à rebours courses">
        <div class="count-main">
          <div class="count-label">TransLantau — départ</div>
          <div class="count-grid" id="mainCountdown"></div>
        </div>
        <div class="subcounts" id="subCountdowns"></div>
      </aside>
    </header>

    <nav class="topnav" aria-label="Navigation page">
      <a href="#dashboard">Dashboard</a>
      <a href="#volume">Volume</a>
      <a href="#atlctl">ATL/CTL</a>
      <a href="#timeline">Semaines</a>
      <a href="#phases">Blocs</a>
      <a href="#radar">Radar</a>
      <a href="#journal">Journal</a>
      <a href="#rules">Règles</a>
    </nav>

    <section id="dashboard">
      <div class="section-head">
        <div>
          <h2>Tableau de bord — KPI temps réel</h2>
          <p>Calculs dérivés de PLAN et des saisies localStorage. Le cardio n’est pas le facteur limitant. La durabilité musculaire décide.</p>
        </div>
        <div class="section-actions">
          <label class="toggle-row"><input type="checkbox" id="includeRaceToggle"> Inclure S21 course dans les réalisés</label>
          <select id="nutritionSelect" aria-label="Statut nutrition"></select>
        </div>
      </div>
      <div class="grid kpi-grid" id="kpiGrid"></div>
      <div class="grid three" style="margin-top:12px" id="progressCards"></div>
      <div class="grid two" style="margin-top:12px">
        <div class="card" id="currentWeekCard"></div>
        <div class="card" id="projectionCard"></div>
      </div>
      <div class="grid" style="margin-top:12px" id="alertsBox"></div>
    </section>

    <section id="volume">
      <div class="section-head">
        <div>
          <h2>Graphique volume — 21 semaines</h2>
          <p>Ligne pointillée : cible calculée par moyenne km. Ligne pleine : réel saisi. Le D+ peut être affiché sur axe secondaire.</p>
        </div>
        <label class="toggle-row"><input type="checkbox" id="showDpToggle" checked> Afficher D+</label>
      </div>
      <div class="chart-wrap"><canvas id="volumeChart" aria-label="Graphique volume et D+" role="img"></canvas></div>
      <div class="chart-form" id="inlineWeekForm" aria-live="polite"></div>
    </section>

    <section id="atlctl">
      <div class="section-head">
        <div>
          <h2>ATL / CTL</h2>
          <p>Le ratio ATL/CTL sert à détecter surcharge ou désentraînement. Il ne remplace pas la fraîcheur musculaire.</p>
        </div>
      </div>
      <div class="chart-wrap small"><canvas id="atlChart" aria-label="Graphique ratio ATL CTL" role="img"></canvas></div>
    </section>

    <section id="timeline">
      <div class="section-head">
        <div>
          <h2>Planning semaines</h2>
          <p>21 cartes S1 à S21. Cliquer sur une semaine pour saisir réalisé, fraîcheur, mollet/Achille, crampes et notes.</p>
        </div>
      </div>
      <div class="timeline" id="timelineCards"></div>
    </section>

    <section id="phases">
      <div class="section-head">
        <div>
          <h2>Bilan par bloc</h2>
          <p>Chaque bloc compare le prévu et le réalisé. Les phases terminées affichent les écarts.</p>
        </div>
      </div>
      <div class="grid phase-grid" id="phaseCards"></div>
    </section>

    <section id="radar">
      <div class="section-head">
        <div>
          <h2>Radar qualités</h2>
          <p>Évaluation 1–10. Courbe principale : actuelle. Courbe fantôme : précédente sauvegarde.</p>
        </div>
      </div>
      <div class="radar-layout">
        <div class="chart-wrap small"><canvas id="radarChart" aria-label="Radar qualités trail" role="img"></canvas></div>
        <div>
          <div class="slider-list" id="radarSliders"></div>
          <button class="btn orange" id="saveRadar" style="margin-top:12px">Sauvegarder radar</button>
          <p class="note" id="radarDate"></p>
        </div>
      </div>
    </section>

    <section id="journal">
      <div class="section-head">
        <div>
          <h2>Journal de bord</h2>
          <p>Saisie terrain. Sans données, le pilotage est aveugle.</p>
        </div>
      </div>
      <div class="journal-layout">
        <form class="card" id="journalForm">
          <div class="form-grid">
            <div class="field"><label for="jDate">Date</label><input id="jDate" type="date" required></div>
            <div class="field"><label for="jType">Type</label><select id="jType"></select></div>
            <div class="field"><label for="jFeel">Ressenti</label><select id="jFeel"><option>😴</option><option>😐</option><option selected>💪</option><option>🔥</option></select></div>
