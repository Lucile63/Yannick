      <div class="field"><label for="qKm">Km réel</label><input id="qKm" type="number" min="0" step="0.1" value="${a.km}"></div>
      <div class="field"><label for="qDp">D+ réel</label><input id="qDp" type="number" min="0" step="1" value="${a.dp}"></div>
      <div class="field"><label for="qSessions">Séances réalisées</label><input id="qSessions" type="number" min="0" step="1" value="${a.sessions}"></div>
      <div class="field"><label for="qFresh">Fraîcheur 1–10</label><input id="qFresh" type="number" min="1" max="10" step="1" value="${a.freshness || 6}"></div>
      <div class="field full"><label for="qNotes">Notes</label><textarea id="qNotes">${escapeHtml(a.notes)}</textarea></div>
      <div class="field full"><button class="btn orange" type="submit">Sauvegarder</button></div>
    </form>`;
    $("#quickForm").addEventListener("submit", e => { e.preventDefault(); updateWeek(id,{km:$("#qKm").value,dp:$("#qDp").value,sessions:$("#qSessions").value,freshness:$("#qFresh").value,notes:$("#qNotes").value}); });
    $("#inlineWeekForm").scrollIntoView({behavior:"smooth",block:"nearest"});
  }

  function renderTimeline(){
    const now = today();
    const active = getActiveWeek(now);
    $("#timelineCards").innerHTML = PLAN.map(w=>{
      const cls = ["week-card", w.id===active.id?"active":"", w.type==="race"?"race":""].join(" ");
      return `<button class="${cls}" data-week="${w.id}" aria-label="Ouvrir S${w.id}">
        <div class="week-top"><div><div class="week-id">S${w.id}</div><div class="week-date">${formatDateRange(w.start,w.end)}</div></div><span class="badge ${typeClass(w.type)}">${w.type}</span></div>
        <div class="week-objectif">${w.id===21?"TRANSLANTAU — ":""}${w.objectif}</div>
        <div class="week-meta"><span>${phaseOf(w).label}</span><span>${formatRange(w.kmMin,w.kmMax,"km")} · ${w.dpLabel || formatRange(w.dpMin,w.dpMax,"D+")}</span>${w.course?`<span class="badge race">${w.course.name} · ${w.course.km} km · ${w.course.dp} D+</span>`:""}</div>
        <div class="status">${statusOfWeek(w,now)}</div>
      </button>`;
    }).join("");
    $$(".week-card").forEach(btn=>btn.addEventListener("click",()=>openDrawer(Number(btn.dataset.week))));
  }

  function renderSessionCard(s){
    const meta = [
      s.distance ? `Distance : ${escapeHtml(s.distance)}` : "",
      s.temps ? `Temps : ${escapeHtml(s.temps)}` : "",
      s.dp ? `D+ : ${escapeHtml(s.dp)}` : "",
      s.terrain ? `Terrain : ${escapeHtml(s.terrain)}` : "",
      s.rpe ? `RPE : ${escapeHtml(s.rpe)}` : "",
      s.difficulte ? `Difficulté : ${escapeHtml(s.difficulte)}` : ""
    ].filter(Boolean).map(x=>`<span>${x}</span>`).join("");
    return `<article class="session-card">
      <div class="session-head"><div><div class="session-code">${escapeHtml(s.code)}</div><div class="session-type">${escapeHtml(s.type || s.jour)}</div></div></div>
      <div class="session-meta">${meta}</div>
      <div class="session-content">${escapeHtml(s.contenu)}</div>
      ${s.consignes ? `<div class="session-consigne">${escapeHtml(s.consignes)}</div>` : ""}
    </article>`;
  }

  function openDrawer(id){
    selectedWeekId = id;
    const w = PLAN.find(x=>x.id===id); const a = getWeekActuals(w);
    const drawer = $("#weekDrawer");
    drawer.innerHTML = `<div class="drawer-head"><div><h2>S${w.id} — ${w.objectif}</h2><p class="note">${formatDateRange(w.start,w.end)} · ${phaseOf(w).label} · <span class="badge ${typeClass(w.type)}">${w.type}</span></p></div><button class="close" id="closeDrawer" aria-label="Fermer">×</button></div>
      ${w.course?`<div class="coach-note">Course : ${w.course.name} · ${w.course.km} km · ${w.course.dp} D+ · ${w.course.role}</div>`:""}
      <div class="coach-note">${w.prioriteCoach}</div>
      <h3>Séances prévues — détail V6</h3><div class="session-cards">${w.seances.map(renderSessionCard).join("")}</div>${w.sourceNotes?.length ? `<div class="source-notes">${w.sourceNotes.map(n=>`<div class="coach-note">${escapeHtml(n)}</div>`).join("")}</div>` : ""}
      <form id="drawerForm" style="margin-top:14px"><div class="form-grid">
        <div class="field"><label for="dKm">Km réel</label><input id="dKm" type="number" min="0" step="0.1" value="${a.km}"></div>
        <div class="field"><label for="dDp">D+ réel</label><input id="dDp" type="number" min="0" step="1" value="${a.dp}"></div>
        <div class="field"><label for="dSessions">Séances réalisées</label><input id="dSessions" type="number" min="0" step="1" value="${a.sessions}"></div>
        <div class="field"><label for="dFresh">Fraîcheur</label><input id="dFresh" type="number" min="1" max="10" step="1" value="${a.freshness || 6}"></div>
        <div class="field"><label for="dAchilles">Douleur mollet/Achille</label><select id="dAchilles"><option value="non" ${a.achilles!=="oui"?"selected":""}>Non</option><option value="oui" ${a.achilles==="oui"?"selected":""}>Oui</option></select></div>
        <div class="field"><label for="dCramps">Crampes</label><select id="dCramps"><option value="non" ${a.cramps!=="oui"?"selected":""}>Non</option><option value="oui" ${a.cramps==="oui"?"selected":""}>Oui</option></select></div>
        <div class="field full"><label for="dNotes">Notes libres</label><textarea id="dNotes">${escapeHtml(a.notes)}</textarea></div>
      </div><div class="section-actions" style="margin-top:12px"><button class="btn orange" type="submit">Sauvegarder</button><button class="btn danger" type="button" id="deleteWeek">Effacer cette semaine</button></div></form>`;
    drawer.classList.add("open"); drawer.setAttribute("aria-hidden","false");
    $("#closeDrawer").addEventListener("click", closeDrawer);
    $("#drawerForm").addEventListener("submit", e=>{e.preventDefault();updateWeek(id,{km:$("#dKm").value,dp:$("#dDp").value,sessions:$("#dSessions").value,freshness:$("#dFresh").value,achilles:$("#dAchilles").value,cramps:$("#dCramps").value,notes:$("#dNotes").value});openDrawer(id);});
    $("#deleteWeek").addEventListener("click",()=>{deleteWeek(id);closeDrawer();});
  }
  function closeDrawer(){ const d=$("#weekDrawer"); d.classList.remove("open"); d.setAttribute("aria-hidden","true"); }

  function renderPhases(){
    const now = today();
    $("#phaseCards").innerHTML = PHASES.map(p=>{
      const weeks = PLAN.filter(w=>w.id>=p.start && w.id<=p.end);
      const planKm = weeks.reduce((s,w)=>s+targetKm(w),0);
      const planDp = weeks.reduce((s,w)=>s+targetDp(w),0);
      const act = weeks.reduce((a,w)=>{ const d=getWeekActuals(w); a.km+=d.km; a.dp+=d.dp; return a;},{km:0,dp:0});
      const first = dateLocal(weeks[0].start); const last = new Date(dateLocal(weeks.at(-1).end).getTime()+86400000);
      const status = now < first ? "À venir" : now > last ? "Terminée" : "En cours";
      const pct = planKm ? act.km/planKm*100 : 0;
      return `<article class="card"><div class="phase-title">${p.label}</div><div class="phase-weeks">S${p.start} à S${p.end} · ${status}${status==="Terminée"?" · ✓ Terminée":""}</div>
        <div class="metric-line"><span>Km prévus</span><strong>${fmt1(planKm)}</strong></div><div class="metric-line"><span>Km réalisés</span><strong>${fmt1(act.km)}</strong></div>
        <div class="metric-line"><span>D+ prévu</span><strong>${fmt(planDp)}</strong></div><div class="metric-line"><span>D+ réalisé</span><strong>${fmt(act.dp)}</strong></div>
        <div class="bar ${diffClass(act.km/planKm)}"><span style="width:${clamp(pct,0,120)}%"></span></div>
        <p class="note">Complétion ${fmt1(pct)}%${status==="Terminée"?` · écart km ${fmt1(act.km-planKm)} · écart D+ ${fmt(act.dp-planDp)}`:""}</p></article>`;
    }).join("");
  }

  function renderRadar(){
    const sliders = $("#radarSliders");
    sliders.innerHTML = RADAR_AXES.map(axis=>`<div class="slider-row"><label for="radar-${slug(axis)}"><span>${axis}</span><strong>${radarStore.current?.[axis] ?? 5}</strong></label><input id="radar-${slug(axis)}" type="range" min="1" max="10" value="${radarStore.current?.[axis] ?? 5}" data-axis="${axis}"></div>`).join("");
    sliders.querySelectorAll("input").forEach(input=>input.addEventListener("input",e=>{radarStore.current[e.target.dataset.axis]=num(e.target.value);e.target.previousElementSibling.querySelector("strong").textContent=e.target.value;drawRadar(false);}));
    $("#radarDate").textContent = radarStore.date ? `Dernière sauvegarde : ${new Date(radarStore.date).toLocaleString("fr-FR")}` : "Aucune sauvegarde radar.";
    drawRadar(false);
  }

  function drawRadar(rebuild=true){
    if (!window.Chart) return;
    const ctx = $("#radarChart");
    if (radarChart) radarChart.destroy();
    const current = RADAR_AXES.map(a=>radarStore.current?.[a] ?? 5);
    const datasets = [{label:"Actuel",data:current,borderColor:"#E8622A",backgroundColor:"rgba(232,98,42,.18)",pointBackgroundColor:"#E8622A",borderWidth:2}];
    if (radarStore.previous) datasets.push({label:"Précédent",data:RADAR_AXES.map(a=>radarStore.previous[a] ?? 5),borderColor:"rgba(214,218,226,.52)",backgroundColor:"rgba(214,218,226,.06)",pointBackgroundColor:"rgba(214,218,226,.65)",borderWidth:1});
    radarChart = new Chart(ctx,{type:"radar",data:{labels:RADAR_AXES,datasets},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:"bottom"}},scales:{r:{min:0,max:10,ticks:{stepSize:2,backdropColor:"transparent"},grid:{color:"rgba(138,143,154,.22)"},angleLines:{color:"rgba(138,143,154,.22)"}}}}});
  }

  function saveRadar(){
    const old = safeParse(LS.radar, null);
    radarStore.previous = old?.current || radarStore.previous || null;
    radarStore.date = new Date().toISOString();
    save(LS.radar, radarStore);
    renderRadar();
  }

  function renderJournal(){
    const todayIso = new Date().toISOString().slice(0,10);
    if (!$("#jDate").value) $("#jDate").value = todayIso;
    $("#jType").innerHTML = JOURNAL_TYPES.map(t=>`<option>${t}</option>`).join("");
    $("#journalFilter").innerHTML = `<option value="all">Tous types</option>` + JOURNAL_TYPES.map(t=>`<option>${t}</option>`).join("");
    renderJournalList();
  }

  function renderJournalList(){
    const type = $("#journalFilter")?.value || "all";
    const q = ($("#journalSearch")?.value || "").toLowerCase();
    const filtered = [...journal].filter(j => (type==="all" || j.type===type) && (!q || (j.notes||"").toLowerCase().includes(q))).sort((a,b)=>String(b.date).localeCompare(String(a.date)));
    $("#journalList").innerHTML = filtered.length ? filtered.map(j=>`<article class="journal-item"><div class="journal-head"><div><strong>${j.type} ${j.feel || ""}</strong><div class="journal-meta">${j.date} · ${fmt1(j.km)} km · ${fmt(j.dp)} D+ · RPE ${j.rpe}</div></div><button class="btn danger" data-jdel="${j.id}">Supprimer</button></div><div class="journal-meta">Durée : ${escapeHtml(j.duration || "—")} · Mollet/Achille : ${j.achilles} · Crampes : ${j.cramps}</div>${j.notes?`<div class="journal-note">${escapeHtml(j.notes)}</div>`:""}</article>`).join("") : `<div class="card"><strong>Aucune entrée.</strong><p class="note">Saisie attendue.</p></div>`;
    $$('[data-jdel]').forEach(b=>b.addEventListener("click",()=>{journal=journal.filter(j=>j.id!==b.dataset.jdel);save(LS.journal,journal);renderJournalList();renderDashboard();}));
    renderMonthSummary();
  }

  function renderMonthSummary(){
    const byMonth = {};
    journal.forEach(j=>{ const m=(j.date||"").slice(0,7); if(!m)return; byMonth[m] ||= {km:0,dp:0,count:0}; byMonth[m].km += num(j.km); byMonth[m].dp += num(j.dp); byMonth[m].count += 1; });
    const rows = Object.entries(byMonth).sort((a,b)=>b[0].localeCompare(a[0])).slice(0,8).map(([m,v])=>`<div class="metric-line"><span>${m}</span><strong>${fmt1(v.km)} km · ${fmt(v.dp)} D+ · ${v.count} entrées</strong></div>`);
    $("#monthSummary").innerHTML = `<h3>Résumé mensuel</h3>${rows.length?rows.join(""):'<p class="note">Données insuffisantes.</p>'}`;
  }

  function addJournal(e){
    e.preventDefault();
    const entry = {id:`j_${Date.now()}`,date:$("#jDate").value,type:$("#jType").value,feel:$("#jFeel").value,km:num($("#jKm").value),dp:num($("#jDp").value),duration:$("#jDuration").value,rpe:num($("#jRpe").value),achilles:$("#jAchilles").value,cramps:$("#jCramps").value,notes:$("#jNotes").value};
    journal.push(entry); save(LS.journal,journal); e.target.reset(); $("#jDate").value = new Date().toISOString().slice(0,10); renderJournalList(); renderDashboard();
  }

  function renderQuotes(){
    $("#quoteTrack").innerHTML = QUOTES.map(q=>`<div class="quote-slide"><div>${q}</div></div>`).join("");
    updateQuote();
  }
  let quoteIndex = 0;
  function updateQuote(){ $("#quoteTrack").style.transform = `translateX(-${quoteIndex*100}%)`; }
  function nextQuote(delta=1){ quoteIndex = (quoteIndex + delta + QUOTES.length) % QUOTES.length; updateQuote(); }

  function rotateHeroMantra(){
    const el = $("#heroMantra");
    let i = Math.floor(Math.random()*HERO_MANTRAS.length);
    setInterval(()=>{ el.style.opacity = 0; setTimeout(()=>{ i=(i+1)%HERO_MANTRAS.length; el.textContent = HERO_MANTRAS[i]; el.style.opacity = 1; },460); },30000);
  }

  function renderFooterStats(timeProgress){
    const totals = actualTotals();
    $("#footerStats").innerHTML = [
      ["Total km plan", `${fmt1(totalPlanKm())} km`],
      ["Total D+ plan", `${fmt(totalPlanDp())} m`],
      ["Séances prévues", fmt(totalSessions())],
      ["Progression globale", `${fmt1(timeProgress)}% temps · ${fmt1(totals.km/totalPlanKm()*100)}% km`]
    ].map(x=>`<div class="card"><div class="kpi-title">${x[0]}</div><div class="kpi-value small-value">${x[1]}</div></div>`).join("");
  }

  function bindEvents(){
    $("#includeRaceToggle")?.addEventListener("change",e=>{uiSettings.includeRace=e.target.checked;save(LS.ui,uiSettings);renderAll(false);});
    $("#showDpToggle")?.addEventListener("change",e=>{uiSettings.showDp=e.target.checked;save(LS.ui,uiSettings);renderCharts();});
    $("#nutritionSelect")?.addEventListener("change",e=>{nutritionStatus=e.target.value; if(nutritionStatus==="auto") localStorage.removeItem(LS.nutrition); else localStorage.setItem(LS.nutrition,nutritionStatus); renderDashboard();});
    $("#saveRadar")?.addEventListener("click",saveRadar);
    $("#journalForm")?.addEventListener("submit",addJournal);
    $("#journalFilter")?.addEventListener("change",renderJournalList);
    $("#journalSearch")?.addEventListener("input",renderJournalList);
    $("#prevQuote")?.addEventListener("click",()=>nextQuote(-1));
    $("#nextQuote")?.addEventListener("click",()=>nextQuote(1));
    document.addEventListener("keydown",e=>{ if(e.key==="Escape") closeDrawer(); });
  }

  function renderAll(rebind=true){
    renderCountdowns(); renderDashboard(); renderCharts(); renderTimeline(); renderPhases(); renderRadar(); renderJournal(); renderQuotes(); if(rebind) bindEvents();
  }

  function formatRange(a,b,unit){
    if (unit === "D+") return a===b ? `${fmt(a)} D+` : `${fmt(a)}–${fmt(b)} D+`;
    return a===b ? `${fmt1(a)} ${unit}` : `${fmt1(a)}–${fmt1(b)} ${unit}`;
  }
  function formatDateRange(s,e){
    const opt = {day:"2-digit",month:"short"};
    return `${dateLocal(s).toLocaleDateString("fr-FR",opt)} – ${dateLocal(e).toLocaleDateString("fr-FR",opt)}`.replace(/\./g,"");
  }
  function escapeHtml(str){ return String(str ?? "").replace(/[&<>'"]/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;","'":"&#39;",'"':"&quot;"}[c])); }
  function slug(s){return s.normalize("NFD").replace(/[\u0300-\u036f]/g,"").replace(/[^a-z0-9]+/gi,"-").toLowerCase();}

  document.addEventListener("DOMContentLoaded",()=>{
    renderAll(true);
    rotateHeroMantra();
    setInterval(renderCountdowns,1000);
    setInterval(()=>nextQuote(1),5000);
  });
  </script>
</body>
</html>
