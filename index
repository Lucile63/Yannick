  const backgroundZonesPlugin = {
    id:"backgroundZones",
    beforeDatasetsDraw(chart){
      const {ctx, chartArea, scales} = chart;
      if (!chartArea || !scales.x) return;
      const xScale = scales.x;
      PLAN.forEach((w,i)=>{
        const x = xScale.getPixelForValue(i);
        const prev = i===0 ? chartArea.left : (xScale.getPixelForValue(i-1)+x)/2;
        const next = i===PLAN.length-1 ? chartArea.right : (xScale.getPixelForValue(i+1)+x)/2;
        const colors = {"récupération":"rgba(29,179,122,.08)","pic":"rgba(46,143,224,.10)","affûtage":"rgba(214,218,226,.07)","course préparatoire":"rgba(232,98,42,.10)","race":"rgba(255,116,46,.16)"};
        const fill = colors[w.type] || (w.type === "spécifique" ? "rgba(232,98,42,.06)" : "rgba(232,98,42,.035)");
        ctx.save();ctx.fillStyle = fill;ctx.fillRect(prev, chartArea.top, next-prev, chartArea.bottom-chartArea.top);ctx.restore();
      });
    },
    afterDatasetsDraw(chart){
      if (!chart.chartArea || !chart.scales.x) return;
      const {ctx, chartArea, scales} = chart;
      const markers = [{i:5,t:"6000D"},{i:10,t:"Luzi"},{i:11,t:"Dolmens"},{i:20,t:"TransLantau"}];
      markers.forEach(m=>{
        const x = scales.x.getPixelForValue(m.i);
        ctx.save();ctx.strokeStyle="rgba(255,255,255,.34)";ctx.setLineDash([4,5]);ctx.beginPath();ctx.moveTo(x,chartArea.top);ctx.lineTo(x,chartArea.bottom);ctx.stroke();ctx.setLineDash([]);ctx.fillStyle="#DDE2EA";ctx.font="700 11px Inter";ctx.fillText(m.t,x+5,chartArea.top+14);ctx.restore();
      });
    }
  };

  const atlZonesPlugin = {
    id:"atlZones",
    beforeDatasetsDraw(chart){
      const {ctx, chartArea, scales} = chart;
      if (!chartArea || !scales.y) return;
      function zone(y1,y2,color){
        const top = scales.y.getPixelForValue(y2), bottom = scales.y.getPixelForValue(y1);
        ctx.save();ctx.fillStyle=color;ctx.fillRect(chartArea.left, top, chartArea.right-chartArea.left, bottom-top);ctx.restore();
      }
      zone(.8,1.3,"rgba(29,179,122,.10)");
      zone(.5,.8,"rgba(232,98,42,.08)"); zone(1.3,1.5,"rgba(232,98,42,.08)");
      zone(0,.5,"rgba(232,58,42,.08)"); zone(1.5,2,"rgba(232,58,42,.08)");
    }
  };

