  function getEnteredWeeks(){
    return PLAN.filter(w => weekData[w.id] && (weekData[w.id].km !== undefined || weekData[w.id].dp !== undefined || weekData[w.id].sessions !== undefined));
  }

  function actualTotals(){
    const includeRace = uiSettings.includeRace;
    return PLAN.reduce((acc,w)=>{
      if (w.id === 21 && !includeRace) return acc;
      const a = getWeekActuals(w);
      acc.km += a.km; acc.dp += a.dp; acc.sessions += a.sessions;
      return acc;
    },{km:0,dp:0,sessions:0});
  }

  function activeWeekCount(now = today()){
    return PLAN.filter(w => new Date(dateLocal(w.end).getTime()+86400000) < now).length;
  }

  function remainingWeeks(now = today()){
    const active = getActiveWeek(now);
    return Math.max(0, 21 - active.id + 1);
  }

  function diffClass(ratio){
    const delta = ratio - 1;
    if (Math.abs(delta) <= .10) return "green";
    if (Math.abs(delta) <= .20) return "orange";
    return "red";
  }

  function freshnessClass(f){
    if (!f) return "";
    if (f >= 7) return "green";
    if (f >= 4) return "orange";
    return "red";
  }

  function atlCtlForWeek(index){
    const weeksUpTo = PLAN.slice(0,index+1).filter(w => weekData[w.id] && weekData[w.id].km !== undefined);
    const current = PLAN[index];
    const currentKm = weekData[current.id]?.km;
    if (currentKm === undefined) return null;
    const last4 = weeksUpTo.slice(-4).map(w => num(weekData[w.id].km));
    if (!last4.length) return null;
    const ctl = last4.reduce((a,b)=>a+b,0)/last4.length;
    if (!ctl) return null;
    return {atl:num(currentKm), ctl, ratio:num(currentKm)/ctl};
  }

  function latestEntryDate(){
    const dates = [];
    Object.values(weekData).forEach(d => { if (d.updatedAt) dates.push(new Date(d.updatedAt)); });
    journal.forEach(j => { if (j.date) dates.push(dateLocal(j.date)); });
    if (!dates.length) return null;
    return new Date(Math.max(...dates.map(d=>d.getTime())));
  }

  function buildCountdown(targetDate){
    const diff = Math.max(0, targetDate - new Date());
    const days = Math.floor(diff/86400000);
    const hours = Math.floor(diff%86400000/3600000);
    const mins = Math.floor(diff%3600000/60000);
    const secs = Math.floor(diff%60000/1000);
    return {days,hours,mins,secs};
  }

