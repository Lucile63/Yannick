  function today(){ return new Date(); }

  function getActiveWeek(now = today()){
    let active = PLAN[0];
    for (const w of PLAN){ if (dateLocal(w.start) <= now) active = w; }
    if (now < dateLocal(PLAN[0].start)) return PLAN[0];
    return active;
  }

  function statusOfWeek(w, now = today()){
    const start = dateLocal(w.start);
    const end = new Date(dateLocal(w.end).getTime() + 86400000);
